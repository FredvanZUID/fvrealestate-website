# =============================================================================
# FV Real Estate — .gitignore
# =============================================================================

# --- OS bestanden ---
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# --- Editor & IDE ---
.vscode/
.idea/
*.swp
*.swo
*~
.sublime-project
.sublime-workspace

# --- Node.js (indien tooling aanwezig) ---
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.npm
.yarn-integrity
package-lock.json
yarn.lock

# --- Build output ---
dist/
build/
.cache/
.parcel-cache/
.next/
.nuxt/

# --- Environment & secrets ---
.env
.env.*
.env.local
.env.development
.env.production
*.pem
*.key
secrets.json

# --- Logs ---
*.log
logs/

# --- Tijdelijke bestanden ---
*.tmp
*.temp
.tmp/

# --- Netlify ---
.netlify/

# --- Test output ---
coverage/
.nyc_output/

# --- Lighthouse / audit output ---
*.json.bak
lhr-*.json
